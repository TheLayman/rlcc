# Nukkad push target:
#   POST http://<server-ip>:8001/v1/rlcc/launch-event
# Required headers:
#   Content-Type: application/json
#   x-authorization-key: <NUKKAD_PUSH_AUTH_KEY>
# Receiver accepts both normal JSON and stringified JSON payloads.
NUKKAD_PUSH_AUTH_KEY=replace-with-shared-push-key
EXTERNAL_SALES_URL=https://integrations.fnb.posifly.in/v1/sales/getSalesWithItems
EXTERNAL_SALES_HEADER_TOKEN=replace-with-sales-api-token
REDIS_URL=redis://127.0.0.1:6379
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
CV_HOST=0.0.0.0
CV_PORT=8000
DASHBOARD_PORT=5173
VIDEO_BUFFER_MINUTES=5
VIDEO_RETENTION_DAYS=2
SALES_RECONCILIATION_MINUTES=2
SALES_RECONCILIATION_LOOKBACK_MINUTES=10
# Optional override. If left empty, RLCC uses yolov8m on GPU and yolov8s on CPU.
YOLO_MODEL_PATH=
CV_FORCE_CPU=0
